{
  "name": "@diagram-copilot/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server.d.ts",
      "development": "./src/server.ts",
      "default": "./dist/server.js"
    }
  },
  "bin": {
    "diagram-copilot-server": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts --workspace ../../examples",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@diagram-copilot/core": "workspace:*",
    "@diagram-copilot/icons": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^4",
    "ws": "^8",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22",
    "@types/ws": "^8",
    "tsx": "^4",
    "typescript": "~5.6",
    "vitest": "^2"
  }
}
