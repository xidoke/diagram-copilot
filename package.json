{
  "name": "diagram-copilot",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "dev": "pnpm --parallel --filter @diagram-copilot/server --filter @diagram-copilot/web dev",
    "dev:server": "pnpm --filter @diagram-copilot/server dev",
    "dev:web": "pnpm --filter @diagram-copilot/web dev",
    "icons:aws": "pnpm --filter @diagram-copilot/icons icons:aws"
  },
  "devDependencies": {
    "typescript": "~5.6",
    "vitest": "^2"
  }
}
